@page "{nid:int}"
@model RestaurantSystem.Pages.Order.IndexModel
@{
    Layout = "_HomeLayout";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Modern Order Page</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Icons -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

      <link rel="stylesheet" href="~/css//Order.css" />
</head>
<body>

    <div class="container-fluid">
        <div class="row g-0 flex-column-reverse flex-lg-row">

            <!-- LEFT -->
            
            <div class="col-lg-5 left-side">

                <span class="text-warning fw-bold mb-3">
                    Hasan Jakmara
                </span>

                <h1 class="food-title">
                    @Model.Item.Name
                </h1>

                <p class="food-desc">
                    @Model.Item.Description

                </p>
                
                
                <div  class="price">
                    <span id="priceID" >$@Model.Item.Price</span>
                </div>

                

                <!-- Quantity -->
                <div class="quantity-box">

                    <button class="qty-btn" onclick="decreaseQty()">
                        <i class="fa-solid fa-minus"></i>
                    </button>

                    <span class="qty-number" id="qty">
                        1
                    </span>

                    <button class="qty-btn" onclick="increaseQty()">
                        <i class="fa-solid fa-plus"></i>
                    </button>

                </div>
                <form method="post" asp-page-handler="Add">
                    <input type="hidden" asp-for="Quantity" id="QuantityInput" value="1" />
                <!-- Button -->
                <button type="submit" class="order-btn w-100">
                    <i class="fa-solid fa-bag-shopping me-2"></i>
                    Order Now
                </button>
                    <input type="hidden" asp-for="Id" value="@Model.Item.Id" />
                    <input type="hidden" asp-for="CategoryIDs" value="@Model.Item.CategoryId" />

            </form>
            </div>
            <!-- RIGHT -->
            <div class="col-lg-7 right-side p-0 ">

                <div class="badge-custom">
                    🔥 Best Seller
                </div>

                <img class="food-image object-fit-cover"
                     src="@Url.Content(Model.Item.ImagePath)"
                     alt="@Model.Item.Name">

            </div>

        </div>
    </div>

    <script>

                      let qty = 1;

           
            let basePrice = parseFloat(
                document.getElementById("priceID").innerText.replace("$", "")
            );

            function increaseQty(){
                qty++;

                document.getElementById("qty").innerText = qty;
                document.getElementById("QuantityInput").value = qty;

                let total = basePrice * qty;

                document.getElementById("priceID").innerText = "$" + total;
            }

            function decreaseQty(){

                if(qty > 1){
                    qty--;

                    document.getElementById("qty").innerText = qty;
                    document.getElementById("QuantityInput").value = qty;

                    let total = basePrice * qty;

                    document.getElementById("priceID").innerText = "$" + total;
                }
            }

    </script>

</body>
</html>