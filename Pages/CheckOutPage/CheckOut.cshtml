@page
@model RestaurantSystem.Pages.CheckOutPage.CheckOutModel
@{
    Layout = "_HomeLayout";
}

<div class="container mt-5">
    <form method="post">


    <div class="row g-4">

        <!-- LEFT SIDE -->
        <div class="col-lg-8">

            <div class="card border-0  shadow-lg rounded-4 p-4 mt-5">

                <h3 class="mb-4">
                    Order Summary
                </h3>

                @foreach(var item in Model.CartItems)
                {
                    <div class="d-flex justify-content-between align-items-center mb-4">

                        <div class="d-flex align-items-center">

                            <img src="@item.MenuItem.ImagePath"
                                 width="90"
                                 height="90"
                                 class="rounded-3 object-fit-cover me-3"/>

                            <div>

                                <h5 class="mb-1">
                                    @item.MenuItem.Name
                                </h5>

                                <p class="text-muted mb-1">
                                    Quantity : @item.Quantity
                                </p>

                                <small class="text-secondary">
                                    $@item.MenuItem.Price each
                                </small>

                            </div>

                        </div>

                        <h5 class="fw-bold">
                            $
                            @(item.Quantity * item.MenuItem.Price)
                        </h5>

                    </div>

                    <hr />
                }

            </div>

        </div>
    
        <!-- RIGHT SIDE -->
        <div class="col-lg-4">

            <div class="card border-0 shadow-lg rounded-4 p-4 mt-5 ">

                <h3 class="mb-4">
                    Payment Details
                </h3>

                <div class="mb-3">

                    <label class="form-label fw-semibold">
                        Card Holder
                    </label>

                    <input type="text"
                        asp-for="info.Name"
                           class="form-control rounded-3"
                           placeholder="Hassan Kamal Jakmara"/>
                        <span class="text-danger fst-italic" asp-validation-for="info.Name"></span>

                </div>

                <div class="mb-3">

                    <label class="form-label fw-semibold">
                        Card Number
                    </label>

                    <input type="text"

                            asp-for="info.VisaNumber"   
                           class="form-control rounded-3"
                           placeholder="1234 5678 9012 3456"/>
                        <span class="text-danger fst-italic" asp-validation-for="info.VisaNumber"></span>

                </div>

                <div class="row">

                    <div class="col-6 mb-3">

                        <label class="form-label fw-semibold">
                            Expiry
                        </label>

                        <input type="text"
                                   asp-for="info.Expiry"
                                   class="form-control rounded-3"
                               placeholder="MM/YY"/>
                            <span class="text-danger fst-italic" asp-validation-for="info.Expiry"></span>

                    </div>

                    <div class="col-6 mb-3">

                        <label class="form-label fw-semibold">
                            CVV
                        </label>

                        <input type="text"
                                   asp-for="info.CVV"
                                   class="form-control rounded-3"
                               placeholder="123"/>
                            <span class="text-danger fst-italic" asp-validation-for="info.CVV"></span>

                    </div>

                </div>

                <hr class="my-4"/>

                <div class="d-flex justify-content-between mb-2">

                    <span class="text-muted">
                        Subtotal
                    </span>

                    <span>
                        $@Model.Total
                    </span>

                </div>

                <div class="d-flex justify-content-between mb-2">

                    <span class="text-muted">
                        Delivery
                    </span>

                    <span>
                        $5
                    </span>

                </div>

                <div class="d-flex justify-content-between fs-4 fw-bold mt-3">

                    <span>
                        Total
                    </span>

                    <span>
                        $@(Model.Total + 5)
                    </span>

                </div>
              
                <button class="btn btn-dark w-100 rounded-3 mt-4 py-3 fs-5">

                    Place Order

                </button>
               
            </div>

        </div>
    </div>
    </form>

</div>