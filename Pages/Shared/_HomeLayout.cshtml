<!DOCTYPE html>

<html>
<head>
    
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"]</title>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet"
          href="~/css/Category.css"
          asp-append-version="true" />
</head>
<body >
    @{
        var userId = Context.Session.GetInt32("UserId");
    }
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark fixed-top custom-navbar">
            <div class="container">

                <a class="navbar-brand" href="/Home/Index">
                    🍽 Foodie
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarNav">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <div class="collapse navbar-collapse" id="navbarNav">

                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">
                            <a class="nav-link" href="/Home/Index">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="/Home/Index#categories">Categories</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="/Home/Index#popular">Popular</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="/Cart">Cart</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="/Home/Index#about">About</a>
                        </li>

                    </ul>

                    @if (userId is null)
                    {
                        <a href="/Account/Login" class="btn btn-outline-light me-2">
                            Login
                        </a>

                        <a href="/Account/Register" class="btn btn-warning">
                            Register
                        </a>
                    }
                    else
                    {
                        <a href="/Account/Login" class="btn btn-danger">
                            Sign Out
                        </a>
                    }

                </div>

            </div>
        </nav>
    </header>
    <div>
        @RenderBody()
    </div>
    <!-- FOOTER -->

</body>

</html>
