@page 
@model RestaurantSystem.Pages.Admin.AdminDashboardModel

@{
    Layout = "_AdminLayout";

    ViewData["Title"] = "Admin Dashboard";

    int? adminCheck =
  HttpContext.Session.GetInt32("admin");
}
@if(adminCheck is null )
{
     <script>
        window.location.href = "/Account/Login";
     </script>
}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<link rel="stylesheet" href="~/css/DashboardAdminStyle.css" />

<div class="container py-4">

    <h1 class="dashboard-title">Admin Dashboard</h1>

    <div class="row g-4">

        <!-- Orders -->
        <div class="col-md-3">
            <div class="card-box bg-orders">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="card-number">@Model.TotalOrders</div>
                        <div class="card-text">Total Orders</div>
                    </div>

                    <div class="card-icon">
                        📦
                    </div>
                </div>
            </div>
        </div>

        <!-- Users -->
        <div class="col-md-3">
            <div class="card-box bg-users">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="card-number">@Model.TotalUsers</div>
                        <div class="card-text">Users</div>
                    </div>

                    <div class="card-icon">
                        👤
                    </div>
                </div>
            </div>
        </div>

        <!-- Categories -->
        <div class="col-md-3">
            <div class="card-box bg-categories">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="card-number">@Model.TotalCategories</div>
                        <div class="card-text">Categories</div>
                    </div>

                    <div class="card-icon">
                        🍔
                    </div>
                </div>
            </div>
        </div>

        <!-- Menu Items -->
        <div class="col-md-3">
            <div class="card-box bg-menu">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="card-number">@Model.TotalMenuItems</div>
                        <div class="card-text">Menu Items</div>
                    </div>

                    <div class="card-icon">
                        🍕
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- Recent Orders -->
    <div class="table-box">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h3>Recent Orders</h3>

            <a asp-page="/Admin/Orders/Index" class="btn btn-dark">
                View All
            </a>
        </div>

        <table class="table table-hover align-middle">

            <thead class="table-dark">
                <tr>
                    <th>Order ID</th>
                    <th>Customer</th>
                    <th>Total</th>
                    <th>Status</th>
                </tr>
            </thead>

            <tbody>
                @for (int i = 0; i < Model.RecentOrders.Count; i++)
                {
                    <tr>
                        <td>#@Model.RecentUser[i].Id</td>
                        <td>@Model.RecentUser[i].Name</td>
                        <td>@Model.RecentOrders[i].TotalPrice</td>
                        <td>
                            @if (@Model.RecentOrders[i].Status == "Completed")
                            {
                                <span class="badge bg-success">
                                    Completed
                                </span>
                            }
                            else if (@Model.RecentOrders[i].Status == "Pending")
                            {
                                <span class="badge bg-warning text-dark">
                                    Pending
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger">
                                    Cancelled
                                </span>
                            }
                        </td>
                    </tr>

                    
                }
            </tbody>

        </table>

    </div>

</div>