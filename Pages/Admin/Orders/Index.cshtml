@page
@model RestaurantSystem.Pages.Admin.Orders.IndexModel

@{
    Layout = null;
    ViewData["Title"] = "All Orders";
}
<style>
body{
        background-color: rgba(20, 20, 20, 0.9) !important;
}    
</style>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container py-5 ">

    <h1 class="mb-4 text-white">
        All Orders
    </h1>
    <div class="mb-4">

        <a asp-page="/Admin/AdminDashboard" class="btn btn-secondary">
            ← Back To Dashboard
        </a>

    </div>
    <table class="table table-hover table-bordered align-middle rounded-1">

        <thead class="table-dark">

            <tr>
                <th>Order Id</th>
                <th>Customer</th>
                <th>Total Price</th>
                <th>Status</th>
                <th>Action</th>
            </tr>

        </thead>

        <tbody>

            @for (int i = 0; i < Model.RecentOrders.Count; i++)
            {
                <tr id="order-@Model.RecentOrders[i].Id">

                    <td>
                        #@Model.RecentOrders[i].Id
                    </td>

                    <td>
                        @Model.RecentUser[i].Name
                    </td>

                    <td>
                        $@Model.RecentOrders[i].TotalPrice
                    </td>

                    <td>

                        @if (Model.RecentOrders[i].Status == "Completed")
                        {
                            <span class="badge bg-success">
                                Completed
                            </span>
                        }
                        else if (Model.RecentOrders[i].Status == "Pending")
                        {
                            <span class="badge bg-warning text-dark">
                                Pending
                            </span>
                        }
                        else if (Model.RecentOrders[i].Status == "Processing")
                        {
                            <span class="badge bg-primary text-white">
                                Processing
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger">
                                Cancelled
                            </span>
                        }

                    </td>
                        <td>
                        <div class="d-flex align-items-center">
                            @if (Model.RecentOrders[i].Status == "Pending")
                            {
                                <!-- Start Processing -->
                                <form method="post" asp-page-handler="Start" class="d-inline">
                                    <input type="hidden" name="id" value="@Model.RecentOrders[i].Id" />
                                    <input type="hidden" name="returnUrl" value="#order-@Model.RecentOrders[i].Id" />

                                    <button class="btn btn-sm btn-primary">
                                        Start
                                    </button>
                                </form>

                                <!-- Cancel -->
                                <form method="post" asp-page-handler="Cancel" class="d-inline">
                                    <input type="hidden" name="id" value="@Model.RecentOrders[i].Id" />
                                <input type="hidden" name="returnUrl" value="#order-@Model.RecentOrders[i].Id" />
                                    <button class="btn btn-sm btn-danger">
                                        Cancel
                                    </button>
                                </form>
                            }
                            else if (Model.RecentOrders[i].Status == "Processing")
                            {
                                <!-- Complete -->
                                <form method="post" asp-page-handler="Complete" class="d-inline">
                                    <input type="hidden" name="id" value="@Model.RecentOrders[i].Id" />
                                    <input type="hidden" name="returnUrl" value="#order-@Model.RecentOrders[i].Id" />

                                    <button class="btn btn-sm btn-success">
                                        Complete
                                    </button>
                                </form>
                            }
                            else if (Model.RecentOrders[i].Status == "Completed")
                            {
                                <span class="text-success fw-bold">
                                    ✔ Done
                                </span>
                            }
                            else
                            {
                                <span class="text-danger fw-bold">
                                    ❌ Cancelled
                                </span>
                            }

                            <!-- Details Button (always visible) -->
                            <a asp-page="Details" asp-route-Orderid="@Model.RecentOrders[i].Id"
                           class="btn btn-sm btn-info  ms-auto">
                                Details
                            </a>
</div>
                        </td>

                </tr>
            }

        </tbody>

    </table>

</div>