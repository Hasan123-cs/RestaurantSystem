@page "{Orderid:int}"

@model RestaurantSystem.Pages.Admin.Orders.DetailsModel
@{
    Layout = null;
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="~/css//Details.css" rel="stylesheet"/>

<div class="container py-5">

    <!-- Title -->
    <h1 class="mb-4">Order Details</h1>

    <!-- Back -->
    <a asp-page="Index" class="btn btn-secondary mb-4">
        ← Back To Orders
    </a>

    <!-- Order Info -->
    <div class="card p-4 mb-4 shadow">

        <h4 class="mb-3   text-warning">Order Info</h4>

        <p class="text-white"><strong>Order ID:</strong> #@Model.Order.Id</p>

        <p>
            <strong class="text-white">Status:</strong>
            <span class="badge text-white "
                @(Model.Order.Status == "Completed" ? "bg-success" :
                  Model.Order.Status == "Pending" ? "bg-warning text-dark" :
                  Model.Order.Status == "Processing" ? "bg-primary" :
                  "bg-danger")">
                @Model.Order.Status
            </span>
        </p>

        <p class="text-white"><strong>Total Price:</strong> $@Model.Order.TotalPrice</p>

        <p class="text-white"><strong>Date:</strong> @Model.Order.OrderDate.ToLocalTime()</p>

    </div>

    <!-- Items -->
    <div class="card p-4 shadow">

        <h4 class="mb-3">Order Items</h4>

        <table class="table table-dark table-hover">

            <thead>
                <tr>
                    <th>Item ID</th>
                    <th>Quantity</th>
                    <th>Price</th>
                    <th>Total</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.MenuItemId</td>
                        <td>@item.Quantity</td>
                        <td>$@item.MenuItem.Price</td>
                        <td>$@(item.MenuItem.Price * item.Quantity)</td>
                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>