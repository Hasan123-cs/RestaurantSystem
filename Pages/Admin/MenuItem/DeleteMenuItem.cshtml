@page "{id:int}"
@model RestaurantSystem.Pages.Admin.MenuItem.DeleteMenuItemModel
@{
    Layout = "_AdminLayout";

}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />


<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-7">

            <div class="card shadow border-0 rounded-4">

                <div class="card-header bg-danger text-white rounded-top-4">
                    <h3 class="mb-0">Delete Menu Item</h3>
                </div>

                <div class="card-body p-4">

                    <form method="post">

                        <!-- Hidden Id -->
                        <input type="hidden" asp-for="MenuItem.Id" />

                        <!-- Warning -->
                        <div class="alert alert-warning">

                            <h5 class="fw-bold">
                                Are you sure you want to delete this item?
                            </h5>

                            <p class="mb-0">
                                This action cannot be undone.
                            </p>

                        </div>

                        <!-- Image -->
                        <div class="text-center mb-4">

                            <img src="@Model.MenuItem.ImagePath"
                                 width="220"
                                 class="rounded shadow border" />

                        </div>

                        <!-- Item Info -->
                        <div class="mb-3">

                            <label class="form-label fw-bold">
                                Item Name
                            </label>

                            <input value="@Model.MenuItem.Name"
                                   class="form-control"
                                   disabled />

                        </div>

                        <div class="mb-3">

                            <label class="form-label fw-bold">
                                Description
                            </label>

                            <textarea class="form-control"
                                      rows="3"
                                      disabled>@Model.MenuItem.Description</textarea>

                        </div>

                        <div class="mb-4">

                            <label class="form-label fw-bold">
                                Price
                            </label>

                            <input value="@Model.MenuItem.Price"
                                   class="form-control"
                                   disabled />

                        </div>

                        <!-- Buttons -->
                        <div class="d-flex gap-2">

                            <button type="submit"
                                    class="btn btn-danger px-4">

                                Delete
                            </button>

                            <a asp-page="/Admin/AdminDashboard"
                               class="btn btn-secondary px-4">

                                Cancel
                            </a>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>