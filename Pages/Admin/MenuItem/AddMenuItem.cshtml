@page
@model RestaurantSystem.Pages.Admin.MenuItem.AddMenuItem
@{
    ViewData["Title"] = "Add Menu Item";
    Layout = "_AdminLayout";
    int? adminCheck =
HttpContext.Session.GetInt32("admin");
}
@if (adminCheck is null)
{
    <script>
        window.location.href = "/Account/Login";
    </script>
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<link href="~/css/MenuItemAdmin.css" rel="stylesheet"/>

<div class="container py-5">

  
    <div class="menu-card">

        <form method="post" enctype="multipart/form-data">

            <div class="row">

                <!-- LEFT SIDE -->
                <div class="col-lg-7">

                    <!-- Name -->
                    <div class="mb-4">
                        <label class="form-label" asp-for="MenuItem.Name"></label>

                        <input type="text"
                               class="form-control"
                               placeholder="Enter item name"
                               asp-for="MenuItem.Name" />
                    </div>

                    <!-- Description -->
                    <div class="mb-4">
                        <label class="form-label" asp-for="MenuItem.Description"></label>

                        <textarea class="form-control"
                                  rows="5"
                                  placeholder="Write item description..."
                                  asp-for="MenuItem.Description"></textarea>
                    </div>

                    <!-- Price -->
                    <div class="mb-4">
                        <label class="form-label" asp-for="MenuItem.Price"></label>

                        <input type="number"
                               step="0.01"
                               class="form-control"
                               placeholder="0.00"
                               asp-for="MenuItem.Price" />
                    </div>

                    <!-- Category -->
                    <div class="mb-4">
                        <label class="form-label">Category</label>

                        <select class="form-select" asp-items="@Model.ListOfCategory" asp-for="MenuItem.CategoryId">

                            <option disabled selected>
                                Select Category
                            </option>

                            

                        </select>
                    </div>

                    <!-- Availability -->
                   

                </div>

                <!-- RIGHT SIDE -->
                <div class="col-lg-5">

                    <label class="form-label mb-3">
                        Upload Image
                    </label>

                    <div class="preview-box mb-3">

                        <img id="previewImage"
                             src="https://via.placeholder.com/400x300?text=Preview"
                             alt="Preview" />

                    </div>

                    <input type="file"
                           class="form-control"
                           id="imageInput"
                           name="ImageFile" />

                </div>

            </div>

            <!-- BUTTON -->
            <div class="mt-4">

                <button type="submit" class="btn-save">
                    Add Menu Item
                </button>

            </div>
            <div asp-validation-summary="All" class=" text-danger bg-warning  ">
            </div>
        </form>
     
    </div>

</div>

<script>

    const imageInput = document.getElementById("imageInput");
    const previewImage = document.getElementById("previewImage");

    imageInput.addEventListener("change", function () {

        const file = this.files[0];

        if (file) {

            const reader = new FileReader();

            reader.onload = function (e) {
                previewImage.src = e.target.result;
            }

            reader.readAsDataURL(file);
        }

    });

</script>