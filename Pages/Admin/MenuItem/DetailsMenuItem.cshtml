@page "{id:int}"
@model RestaurantSystem.Pages.Admin.MenuItem.DetailsMenuItemModel

@{
    ViewData["Title"] = "Menu Item Details";
    Layout = "_AdminLayout";
}

<div class="container py-4">

    <div class="card shadow border-0">

        <div class="card-header bg-dark text-white">
            <h3 class="mb-0">Menu Item Details</h3>
        </div>

        <div class="card-body">

            <div class="row">

                <div class="col-md-4 text-center">

                    <img src="@Model.MenuItem.ImagePath"
                         class="img-fluid rounded shadow-sm"
                         style="height:250px; object-fit:cover;" />

                </div>

                <div class="col-md-8">

                    <h2 class="fw-bold mb-3">
                        @Model.MenuItem.Name
                    </h2>

                    <p class="mb-3">
                        @Model.MenuItem.Description
                    </p>

                    <p class="fs-5">
                        <strong>Price:</strong>
                        $@Model.MenuItem.Price
                    </p>

                    <p class="fs-5">
                        <strong>Category:</strong>
                        @(Model.CategoryName)
                    </p>

                    <a asp-page="Index"
                       class="btn btn-secondary mt-3">
                        Back
                    </a>

                </div>

            </div>

        </div>

    </div>

</div>