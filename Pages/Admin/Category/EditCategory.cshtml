@page "{id:int}"
@model RestaurantSystem.Pages.Admin.Category.EditCategoryModel
@{
    Layout = "_AdminLayout";

}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />


<div class="container mt-5">

    <div class="row">

        <div class="col-md-8 mx-auto">

            <div class="card shadow rounded-4 border-0">

                <div class="card-body p-4">

                    <h2 class="mb-4 fw-bold">
                        Edit Category
                    </h2>

                    <form method="post" enctype="multipart/form-data">

                        <!-- Category Name -->
                        <div class="mb-3">

                            <label class="form-label fw-semibold">
                                Category Name
                            </label>

                            <input asp-for="Category.Name"
                                   class="form-control form-control-lg"
                                   placeholder="Enter category name" />

                            <span asp-validation-for="Category.Name"
                                  class="text-danger">
                            </span>

                        </div>

                        <!-- Current Image -->
                        <div class="mb-3">

                            <label class="form-label fw-semibold">
                                Current Image
                            </label>

                            <br />

                            <img src="@Model.Category.BackgroundImage"
                                 width="150"
                                 class="rounded shadow-sm border" />

                        </div>

                        <!-- Upload New Image -->
                        <div class="mb-4">

                            <label class="form-label fw-semibold">
                                Upload New Image
                            </label>

                            <input type="file" name="newImage"
                                   class="form-control" />

                        </div>

                        <!-- Buttons -->
                        <div class="d-flex gap-2">

                            <button type="submit"
                                    class="btn btn-primary px-4">

                                Update Category

                            </button>

                            <a asp-page="/Admin/AdminDashboard"
                               class="btn btn-secondary px-4">

                                Cancel

                            </a>

                        </div>
                        <input type="hidden" asp-for="Category.Id" value="@Model.Category.Id"/>
                    </form>

                </div>

            </div>

        </div>

    </div>

</div>
