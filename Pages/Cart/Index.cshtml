@page
@model RestaurantSystem.Pages.Cart.IndexModel
@{
    Layout = "_HomeLayout";
    ViewData["Title"] = "Shopping Cart";
}

<div class="container mt-5">
    <h2 class="mb-4 text-center">🛒 Your Cart</h2>

    @if (Model.CartItems.Count == 0)
    {
        <div class="alert alert-info text-center">
            Your cart is empty.
        </div>

        <div class="text-center">
            <a href="../Home" class="btn btn-primary">
                Browse Menu
            </a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-bordered align-middle">

                <thead class="table-dark">
                    <tr>
                        <th>Image</th>
                        <th>Item</th>
                        <th>Price</th>
                        <th width="170">Quantity</th>
                        <th>Total</th>
                        <th>Action</th>
                        <th>Note</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model.CartItems)
                    {
                        <tr>

                            <td>
                                <img src="@Url.Content(item.MenuItem.ImagePath)"
                                     width="80"
                                     height="80"
                                     class="rounded object-fit-cover" />
                            </td>

                            <td>
                                <strong> @item.MenuItem.Name  </strong>
                            </td>

                            <td>
                                $@item.MenuItem.Price
                            </td>

                            <td>

                                <form method="post" asp-page-handler="UpdateQuantity" class="d-flex">

                                    <input type="hidden"
                                           name="cartItemId"
                                           value="@item.Id" />

                                    <input type="number"
                                           name="quantity"
                                           value="@item.Quantity"
                                           min="1"
                                           class="form-control me-2" />

                                    <button type="submit"
                                            class="btn btn-warning btn-sm">
                                        Update
                                    </button>

                                </form>

                            </td>

                            <td>
                                $@(item.Quantity * item.MenuItem.Price)
                            </td>

                            <td>

                                <form method="post" asp-page-handler="Remove">

                                    <input type="hidden"
                                           name="cartItemId"
                                           value="@item.Id" />

                                    <button type="submit"
                                            class="btn btn-danger btn-sm">
                                        Remove
                                    </button>
                                </form>


                            </td>
                            <td>
                            <form method="post" asp-page-handler="AddMoreNote">

                                 <input type="hidden"
                                        name="idCart"
                                        value="@item.Id" />

                                    <textarea style="    
                                    padding: 0 !important;
                                    margin: 0 !important;
                                    text-align: left;
                                    direction: ltr;
                                    text-indent: 0 !important;" name="note"
                                           class="w-100 h-auto fst-italic bg-warning">
                                     @item.Note
                                 </textarea>

                                 <div class="d-flex justify-content-center">
                                     <button type="submit" class="btn btn-primary">
                                         Save Note
                                     </button>
                                 </div>

                                </form>
                            </td>
                           
                        </tr>
                    }

                </tbody>

            </table>
        </div>

        <div class="card shadow-sm p-4 mt-4">

            <div class="d-flex justify-content-between align-items-center">

                <h4>
                    Total:
                    <span class="text-success">
                        $@Model.TotalPrice
                    </span>
                </h4>

                <a asp-page="/CheckOutPage/CheckOut"
                       class="btn btn-success btn-lg">
                    Proceed to Checkout
                </a>

            </div>

        </div>
    }

</div>